# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# =============================================================================
# AI / LLM
# =============================================================================

# Required for LLM-powered /image-query/query (use_llm: true)
GEMINI_API_KEY=your_gemini_api_key_here

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================

# Option A — full URL (takes priority)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Option B — individual parts (used if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=drone_db
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# =============================================================================
# AWS S3 (optional — if not set, frames are saved locally to captured_frames/)
# =============================================================================

AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=us-east-1
S3_BUCKET=your-s3-bucket-name

# S3 object key for the default drone video
VIDEO_S3_KEY=computer-vision/video.mp4

# Optional: CloudFront CDN URL (takes priority over S3 pre-signed URLs)
# VIDEO_CDN_URL=https://your-cloudfront-id.cloudfront.net

# S3 path prefixes (change only if your bucket layout differs)
S3_VIDEO_PREFIX=computer-vision
S3_FRAMES_PREFIX=computer-vision/snapshots

# =============================================================================
# CORS
# =============================================================================

# Comma-separated list of allowed frontend origins.
# Use * only for local development — restrict this in production.
ALLOWED_ORIGINS=https://your-frontend-domain.com
